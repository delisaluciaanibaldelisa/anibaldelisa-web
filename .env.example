# Webhook de n8n para el chat flotante y el formulario de contacto.
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://TU-N8N.com/webhook/anibaldelisa-chat

# Canal de Telegram del negocio (backend del chat, invisible al cliente).
NEXT_PUBLIC_TELEGRAM_USERNAME=@anibaldelisa
NEXT_PUBLIC_TELEGRAM_URL=https://t.me/anibaldelisa

# Emails de confirmación de turnos (resend.com).
RESEND_API_KEY=re_xxxxxxxxxxxx

# Turnos con Google Calendar (service account de Google Cloud).
# Pegar el contenido COMPLETO del archivo .json descargado.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GOOGLE_CALENDAR_ID=xxxxxxxx@group.calendar.google.com
